{
  "openapi": "3.0.0",
  "info": {
    "title": "Configuration API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/configuration",
      "description": "Basepath for the Configuration API"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "summary": "Returns the current status of the API",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "OK"
                }
              }
            }
          }
        }
      }
    },
    "/time": {
      "get": {
        "summary": "Returns the current server time",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "post": {
        "summary": "Create a new submission configuration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Configuration"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Configuration created successfully"
          },
          "400": {
            "description": "Invalid input"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "get": {
        "summary": "List all configurations",
        "responses": {
          "200": {
            "description": "List of configurations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Configuration"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/{submissionId}": {
      "get": {
        "summary": "Get configuration details by submission ID",
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Configuration"
                }
              }
            }
          },
          "404": {
            "description": "Configuration not found"
          }
        }
      }
    },
    "/author/{authorId}": {
      "get": {
        "summary": "Get all configurations for a specific author",
        "parameters": [
          {
            "name": "authorId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of configurations for the author",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Configuration"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Configuration": {
        "type": "object",
        "required": [
          "title",
          "reviewProcessType",
          "authorIds",
          "numberOfExaminers"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "reviewProcessType": {
            "type": "string"
          },
          "authorIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "numberOfExaminers": {
            "type": "integer",
            "minimum": 1
          },
          "submissionDeadline": {
            "type": "string",
            "format": "date-time"
          },
          "reviewDeadline": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
