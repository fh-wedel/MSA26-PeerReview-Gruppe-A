{
  "openapi": "3.0.3",
  "info": {
    "title": "Matching Service API",
    "description": "API for managing reviewer-submission matches and Cognito reviewer proxy operations.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/matching",
      "description": "Basepath for the Matching Service API"
    }
  ],
  "paths": {
    "/matches/submissions/{submissionId}": {
      "get": {
        "operationId": "getMatchesBySubmission",
        "summary": "Returns all matched reviewers and matching status for a submission",
        "tags": [
          "matches"
        ],
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "sub-123e4567-e89b-12d3-a456"
            },
            "description": "The unique identifier of the submission"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching details for the submission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionMatchResponse"
                }
              }
            }
          },
          "403": {
            "description": "Access denied. The Requester is not permitted to use this endpoint.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CognitoErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No matching record found for this submission or the requester does not have permission to view it.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/matches/examiners/{examinerUsername}": {
      "get": {
        "operationId": "getMatchesByExaminer",
        "summary": "Returns all submissions assigned to a specific examiner",
        "description": "The path parameter is the human-readable Cognito username (e.g. 'Marcel'). The service resolves it to the internal Cognito sub UUID for DynamoDB queries and access-control checks.",
        "tags": [
          "matches"
        ],
        "parameters": [
          {
            "name": "examinerUsername",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "Marcel"
            },
            "description": "The Cognito username of the examiner (e.g. 'Marcel'). Not the sub UUID."
          }
        ],
        "responses": {
          "200": {
            "description": "List of submissions assigned to the examiner",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExaminerMatchResponse"
                }
              }
            }
          },
          "403": {
            "description": "Access denied. The Requester is not permitted to use this endpoint.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CognitoErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Examiner not found or no matching records for this examiner, or the requester does not have permission to view them.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SubmissionMatchResponse": {
        "type": "object",
        "properties": {
          "submissionId": {
            "type": "string",
            "description": "The unique identifier of the submission",
            "example": "sub-123e4567-e89b-12d3-a456"
          },
          "status": {
            "type": "string",
            "enum": [
              "MATCHED",
              "FAILED"
            ]
          },
          "reason": {
            "type": "string",
            "nullable": true,
            "description": "Failure reason, only present when status is FAILED",
            "example": "No available reviewers"
          },
          "numberOfExaminers": {
            "type": "integer"
          },
          "submitterId": {
            "type": "string",
            "description": "Cognito sub UUID of the submitter (as stored in DynamoDB)",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "submitterUsername": {
            "type": "string",
            "description": "Cognito username of the submitter, resolved from the submitterId",
            "example": "Marcel"
          },
          "matchedAt": {
            "type": "string",
            "format": "date-time"
          },
          "matches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchEntry"
            }
          }
        },
        "required": [
          "submissionId",
          "status",
          "matchedAt",
          "submitterId",
          "submitterUsername"
        ]
      },
      "MatchEntry": {
        "type": "object",
        "properties": {
          "examinerId": {
            "type": "string",
            "description": "Cognito sub (UUID) of the assigned reviewer",
            "example": "123e4567-e89"
          },
          "examinerUsername": {
            "type": "string",
            "description": "Cognito username of the assigned reviewer",
            "example": "Marcel"
          },
          "assignedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "examinerId",
          "examinerUsername",
          "assignedAt"
        ]
      },
      "ExaminerMatchResponse": {
        "type": "object",
        "properties": {
          "examinerId": {
            "type": "string",
            "description": "Cognito sub UUID of the examiner (resolved from the username path parameter)",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "examinerUsername": {
            "type": "string",
            "description": "Cognito username of the examiner (from the path parameter)",
            "example": "Marcel"
          },
          "assignments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AssignmentEntry"
            }
          }
        },
        "required": [
          "examinerId",
          "examinerUsername",
          "assignments"
        ]
      },
      "AssignmentEntry": {
        "type": "object",
        "properties": {
          "submissionId": {
            "type": "string",
            "description": "The unique identifier of the assigned submission",
            "example": "sub-123e4567-e89b-12d3-a456"
          },
          "assignedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "submissionId",
          "assignedAt"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "message"
        ]
      },
      "CognitoErrorResponse": {
        "type": "object",
        "properties": {
          "Message": {
            "type": "string",
            "description": "Amazon Verified Permissions error message returned by Cognito when access is denied due to insufficient permissions. This typically indicates that the Requester is not in the correct Cognito group.",
            "example": "User is not authorized to access this resource with an explicit deny in an identity-based policy"
          }
        },
        "required": [
          "Message"
        ]
      }
    }
  }
}