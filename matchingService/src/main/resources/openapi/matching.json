{
  "openapi": "3.0.3",
  "info": {
    "title": "Matching Service API",
    "description": "API for managing reviewer-submission matches and Cognito reviewer proxy operations.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/matching",
      "description": "Basepath for the Matching Service API"
    }
  ],
  "paths": {
    "/matches/submissions/{submissionId}": {
      "get": {
        "operationId": "getMatchesBySubmission",
        "summary": "Returns all matched reviewers and matching status for a submission",
        "tags": ["matches"],
        "parameters": [
          {
            "name": "submissionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the submission"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching details for the submission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionMatchResponse"
                }
              }
            }
          },
          "404": {
            "description": "No matching record found for this submission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/matches/examiners/{examinerUsername}": {
      "get": {
        "operationId": "getMatchesByExaminer",
        "summary": "Returns all submissions assigned to a specific examiner",
        "description": "The path parameter is the human-readable Cognito username (e.g. 'Marcel'). The service resolves it to the internal Cognito sub UUID for DynamoDB queries and access-control checks.",
        "tags": ["matches"],
        "parameters": [
          {
            "name": "examinerUsername",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Cognito username of the examiner (e.g. 'Marcel'). Not the sub UUID."
          }
        ],
        "responses": {
          "200": {
            "description": "List of submissions assigned to the examiner",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExaminerMatchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/examiners": {
      "get": {
        "operationId": "listExaminers",
        "summary": "Lists all available reviewers from the Cognito Reviewer group",
        "tags": ["examiners"],
        "responses": {
          "200": {
            "description": "List of all reviewers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ExaminerResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createExaminer",
        "summary": "Creates a new reviewer in the Cognito Reviewer group",
        "tags": ["examiners"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExaminerRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reviewer created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExaminerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/examiners/{examinerUsername}": {
      "get": {
        "operationId": "getExaminer",
        "summary": "Returns details of a specific reviewer from Cognito",
        "tags": ["examiners"],
        "parameters": [
          {
            "name": "examinerUsername",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Cognito username of the reviewer (e.g. 'Marcel'). Not the sub UUID."
          }
        ],
        "responses": {
          "200": {
            "description": "Reviewer details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExaminerResponse"
                }
              }
            }
          },
          "404": {
            "description": "Reviewer not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateExaminer",
        "summary": "Updates the metadata/custom attributes of a reviewer in Cognito",
        "tags": ["examiners"],
        "parameters": [
          {
            "name": "examinerUsername",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Cognito username of the reviewer (e.g. 'Marcel'). Not the sub UUID."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateExaminerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reviewer updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExaminerResponse"
                }
              }
            }
          },
          "404": {
            "description": "Reviewer not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteExaminer",
        "summary": "Deletes a reviewer from the Cognito User Pool",
        "tags": ["examiners"],
        "parameters": [
          {
            "name": "examinerUsername",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Cognito username of the reviewer (e.g. 'Marcel'). Not the sub UUID."
          }
        ],
        "responses": {
          "204": {
            "description": "Reviewer deleted successfully"
          },
          "404": {
            "description": "Reviewer not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SubmissionMatchResponse": {
        "type": "object",
        "properties": {
          "submissionId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["MATCHED", "FAILED"]
          },
          "reason": {
            "type": "string",
            "nullable": true,
            "description": "Failure reason, only present when status is FAILED"
          },
          "numberOfExaminers": {
            "type": "integer"
          },
          "submitterId": {
            "type": "string",
            "description": "Cognito sub UUID of the submitter (as stored in DynamoDB)"
          },
          "matchedAt": {
            "type": "string",
            "format": "date-time"
          },
          "matches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchEntry"
            }
          }
        },
        "required": ["submissionId", "status", "matchedAt"]
      },
      "MatchEntry": {
        "type": "object",
        "properties": {
          "examinerId": {
            "type": "string",
            "description": "Cognito sub (UUID) of the assigned reviewer"
          },
          "assignedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["examinerId", "assignedAt"]
      },
      "ExaminerMatchResponse": {
        "type": "object",
        "properties": {
          "examinerId": {
            "type": "string",
            "description": "Cognito sub UUID of the examiner (resolved from the username path parameter)"
          },
          "assignments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AssignmentEntry"
            }
          }
        },
        "required": ["examinerId", "assignments"]
      },
      "AssignmentEntry": {
        "type": "object",
        "properties": {
          "submissionId": {
            "type": "string"
          },
          "assignedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["submissionId", "assignedAt"]
      },
      "ExaminerResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "Cognito sub (UUID)"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "description": "Cognito user status (e.g., CONFIRMED, FORCE_CHANGE_PASSWORD)"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "customAttributes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom Cognito attributes (e.g., specialty, availability)"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The Cognito groups the user belongs to"
          }
        },
        "required": ["userId", "username", "email"]
      },
      "CreateExaminerRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "The Cognito username (e.g. 'Marcel') of an existing user to promote to reviewer. Not the sub UUID."
          },
          "customAttributes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": ["username"]
      },
      "UpdateExaminerRequest": {
        "type": "object",
        "properties": {
          "customAttributes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom attributes to update on the Cognito user"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["message"]
      }
    }
  }
}