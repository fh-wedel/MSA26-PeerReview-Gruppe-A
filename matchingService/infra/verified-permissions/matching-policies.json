{
    "namespace": "PeerReview",
    "resourceId": "PeerReview",
    "entityTypeNames": {
        "user": "User",
        "group": "UserGroup",
        "application": "Application",
        "action": "Action"
    },
    "policies": [
        {
            "id": "AdminMatchesBySubmission",
            "groupName": "Admin",
            "actionId": "get /api/matching/matches/submissions/{submissionId}",
            "description": "Allow Admin to view matches by submission"
        },
        {
            "id": "AdminMatchesByExaminer",
            "groupName": "Admin",
            "actionId": "get /api/matching/matches/examiners/{examinerUsername}",
            "description": "Allow Admin to view matches by examiner"
        },
        {
            "id": "ReviewerViewOwnMatches",
            "groupName": "Reviewer",
            "actionId": "get /api/matching/matches/examiners/{examinerUsername}",
            "description": "Allow Reviewer to view their own assigned submissions"
        },
        {
            "id": "ReviewerViewMatchesBySubmission",
            "groupName": "Reviewer",
            "actionId": "get /api/matching/matches/submissions/{submissionId}",
            "description": "Allow Reviewer to view matches for submissions they are assigned to"
        },
        {
            "id": "AuthorViewOwnSubmissionMatches",
            "groupName": "Author",
            "actionId": "get /api/matching/matches/submissions/{submissionId}",
            "description": "Allow Author to view matches for their own submission"
        },
        {
            "id": "ExamOfficerViewMatchesBySubmission",
            "groupName": "ExaminationOfficer",
            "actionId": "get /api/matching/matches/submissions/{submissionId}",
            "description": "Allow ExaminationOfficer to view matches for a submission"
        }
    ]
}